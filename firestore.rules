rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function parentPin(tid) {
      return get(/databases/$(database)/documents/tournaments/$(tid)).data.pinHash;
    }
    function hasPin(tid) {
      return request.resource.data._pinHash == parentPin(tid);
    }

    match /tournaments/{tid} {
      allow read: if true;
      allow create: if request.resource.data.pinHash is string;
      // The data layer stamps _pinHash onto the existing document via an
      // update() call (checked against the incoming request payload) BEFORE
      // issuing deleteDoc(). On delete, request.resource is null, so the
      // delete rule must instead verify the stamp already present on the
      // existing document (resource.data), which was just written by the
      // gated update above.
      allow update: if request.resource.data._pinHash == resource.data.pinHash;
      allow delete: if resource.data._pinHash == resource.data.pinHash;

      match /players/{pid} {
        allow read: if true;
        allow create: if hasPin(tid);
        allow update: if hasPin(tid);
        // Same update-then-delete pattern as the parent tournament: the
        // caller updates _pinHash on this doc first (gated by hasPin), then
        // deletes it, so the delete check compares the existing doc's
        // stamped _pinHash against the parent tournament's pinHash.
        allow delete: if resource.data._pinHash == parentPin(tid);
      }
      match /matches/{mid} {
        allow read: if true;
        allow create: if hasPin(tid);
        allow update: if hasPin(tid);
        allow delete: if resource.data._pinHash == parentPin(tid);
      }
    }
  }
}
